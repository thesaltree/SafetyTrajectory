.env
.env.*
!.env.example
*.key
secrets.json

# ── Jupyter ────────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Streamlit ─────────────────────────────────────────────────────────────────
.streamlit/secrets.toml

